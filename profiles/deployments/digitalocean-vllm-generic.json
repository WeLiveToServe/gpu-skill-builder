    "expert_parallel": false,
    "enable_eplb": false,
    "prefix_caching_policy": "enabled",
    "chunked_prefill_policy": "enabled",
    "kv_cache_dtype": "auto",
    "extra_args": []
  },
  "readiness": {
    "require_health_endpoint": true,
    "require_models_endpoint": true,
    "require_smoke_prompt": true,
    "smoke_prompt": "Reply with OK",
    "health_timeout_seconds": 1800
  }
