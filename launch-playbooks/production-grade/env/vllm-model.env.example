# Example environment file for launch-playbooks/production-grade/systemd/vllm-model.service.template

SERVICE_USER=root
WORKING_DIRECTORY=/root
ENV_FILE=/opt/gpu-skill-builder/.env

MODEL_ID=openai/gpt-oss-120b
SERVED_MODEL_NAME=gpt-oss-120b
PORT=8000
VLLM_API_KEY=replace_me
HF_HOME=/mnt/nvme/hf

MAX_MODEL_LEN=131072
GPU_MEMORY_UTILIZATION=0.80
TENSOR_PARALLEL_SIZE=1
PIPELINE_PARALLEL_SIZE=1
KV_CACHE_DTYPE=auto
MAX_NUM_SEQS=4
MAX_NUM_BATCHED_TOKENS=16384

OPTIONAL_EXPERT_PARALLEL_FLAGS=
OPTIONAL_PREFIX_CACHING_FLAG=--enable-prefix-caching
OPTIONAL_CHUNKED_PREFILL_FLAG=--enable-chunked-prefill
OPTIONAL_EXTRA_ARGS=
