    "interactive-stable": {
      "purpose": "Sticky multi-turn agent sessions",
      "max_num_seqs_h200x1": 4,
      "max_num_seqs_h200x8": 4,
      "max_num_batched_tokens": 16384,
      "enable_prefix_caching": true
    },
    "medium-stable": {
      "purpose": "Mixed traffic with some parallelism",
      "max_num_seqs_h200x8": 6,
      "max_num_batched_tokens": 24576,
      "enable_prefix_caching": false
    },
    "harness-eval": {
      "purpose": "Deterministic benchmark and regression runs",
